<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#EAEAEA"
    android:orientation="vertical"
    android:padding="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/mode_switch"
            style="@style/Widget.ConvoyPinyin.KeyButton"
            android:layout_width="64dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="4dp"
            android:text="@string/mode_cn" />

        <TextView
            android:id="@+id/composing_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#D8D8D8"
            android:ellipsize="end"
            android:padding="8dp"
            android:singleLine="true"
            android:text="@string/composing_hint"
            android:textSize="16sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/candidate_prev"
            style="@style/Widget.ConvoyPinyin.KeyButton"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="@string/candidate_prev" />

        <HorizontalScrollView
            android:id="@+id/candidate_scroll"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/candidate_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <Button
            android:id="@+id/candidate_next"
            style="@style/Widget.ConvoyPinyin.KeyButton"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="@string/candidate_next" />

        <Button
            android:id="@+id/candidate_expand"
            style="@style/Widget.ConvoyPinyin.KeyButton"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:text="@string/candidate_expand" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/keyboard_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="vertical">
        <LinearLayout android:id="@+id/row1" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" />
        <LinearLayout android:id="@+id/row2" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" />
        <LinearLayout android:id="@+id/row3" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" />
        <LinearLayout android:id="@+id/row4" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/suggestion_panel"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginTop="6dp"
        android:orientation="horizontal"
        android:visibility="gone">

        <ScrollView
            android:id="@+id/suggestion_scroll"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/suggestion_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical" />
        </ScrollView>

        <LinearLayout
            android:layout_width="48dp"
            android:layout_height="match_parent"
            android:layout_marginStart="4dp"
            android:gravity="center"
            android:orientation="vertical">

            <SeekBar
                android:id="@+id/suggestion_slider"
                android:layout_width="220dp"
                android:layout_height="48dp"
                android:max="100"
                android:rotation="270" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
