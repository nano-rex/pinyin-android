<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#EAEAEA"
    android:orientation="vertical"
    android:padding="4dp">

    <LinearLayout
        android:id="@+id/mode_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:orientation="horizontal">

        <Button
            android:id="@+id/mode_simplified"
            style="@style/Widget.ConvoyPinyin.KeyButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mode_cn" />

        <Button
            android:id="@+id/mode_traditional"
            style="@style/Widget.ConvoyPinyin.KeyButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mode_tw" />

        <Button
            android:id="@+id/mode_english"
            style="@style/Widget.ConvoyPinyin.KeyButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mode_en" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/candidate_prev"
            style="@style/Widget.ConvoyPinyin.KeyButton"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="@string/candidate_prev" />

        <HorizontalScrollView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:fillViewport="true"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/candidate_container"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <Button
            android:id="@+id/candidate_next"
            style="@style/Widget.ConvoyPinyin.KeyButton"
            android:layout_width="48dp"
            android:layout_height="wrap_content"
            android:text="@string/candidate_next" />
    </LinearLayout>

    <TextView
        android:id="@+id/composing_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#D8D8D8"
        android:ellipsize="end"
        android:padding="8dp"
        android:singleLine="true"
        android:text="@string/composing_hint"
        android:textSize="16sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:orientation="vertical">
        <LinearLayout android:id="@+id/row1" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" />
        <LinearLayout android:id="@+id/row2" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" />
        <LinearLayout android:id="@+id/row3" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" />
        <LinearLayout android:id="@+id/row4" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" />
    </LinearLayout>
</LinearLayout>
